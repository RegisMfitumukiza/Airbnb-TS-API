// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum ListingCategory {
  BEACH
  MOUNTAIN
  CITY
  COUNTRYSIDE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum HostRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  HOST_REQUEST
  HOST_APPROVED
  HOST_REJECTED
  BOOKING_CREATED
  BOOKING_CANCELLED
  NEW_REVIEW
  SYSTEM
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  password         String
  phone            String
  role             Role      @default(GUEST)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  avatar           String?
  avatarPublicId   String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  googleId String? @unique

  isBanned  Boolean   @default(false)
  bannedAt  DateTime?
  banReason String?
  bannedById String?

  listings Listing[]
  bookings Booking[]
  reviews  Review[]

  hostRequests         HostRequest[] @relation("UserHostRequests")
  reviewedHostRequests HostRequest[] @relation("ReviewedHostRequests")

  notifications Notification[]

  @@index([role])
}

model Listing {
  id            String      @id @default(uuid())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?

  coverImage         String?
  coverImagePublicId String?

  images          String[] @default([])
  imagesPublicIds String[] @default([])

  available     Boolean         @default(true)
  availableFrom DateTime?
  category      ListingCategory @default(CITY)
  superhost     Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host   User   @relation(fields: [hostId], references: [id])
  hostId String

  bookings Booking[]
  reviews  Review[]

  @@index([hostId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
  @@index([rating])
  @@index([category])
  @@index([available])
  @@index([location, type])
  @@index([location, pricePerNight])
}

model Booking {
  id        String        @id @default(uuid())
  checkIn   DateTime
  checkOut  DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  guest   User   @relation(fields: [guestId], references: [id])
  guestId String

   guests Int @default(1)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  @@index([guestId])
  @@index([listingId])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@index([listingId, checkIn, checkOut])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

model HostRequest {
  id      String            @id @default(uuid())
  message String?
  status  HostRequestStatus @default(PENDING)

  user   User   @relation("UserHostRequests", fields: [userId], references: [id])
  userId String

  reviewedBy   User?   @relation("ReviewedHostRequests", fields: [reviewedById], references: [id])
  reviewedById String?

  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([reviewedById])
}

model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  type    NotificationType
  read    Boolean          @default(false)
  readAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([type])
}