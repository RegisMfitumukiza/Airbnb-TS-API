// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  password         String
  phone            String
  role             Role      @default(GUEST)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  avatar           String?
  avatarPublicId   String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  listings Listing[]
  bookings Booking[]
  reviews  Review[]

  @@index([role])
}

model Listing {
  id            String      @id @default(uuid())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?

  coverImage        String?
  coverImagePublicId String?

  images        String[] @default([])
  imagesPublicIds String[] @default([])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  host   User   @relation(fields: [hostId], references: [id])
  hostId String

  bookings Booking[]
  reviews  Review[]

  @@index([hostId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
  @@index([rating])
  @@index([location, type])
  @@index([location, pricePerNight])
}

model Booking {
  id        String        @id @default(uuid())
  checkIn   DateTime
  checkOut  DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  guest   User   @relation(fields: [guestId], references: [id])
  guestId String

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  @@index([guestId])
  @@index([listingId])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@index([listingId, checkIn, checkOut])
}

model Review {
  id        String      @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])

}
